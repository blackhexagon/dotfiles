[user]
	name = matous
	email = matous.trca@gmail.com
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = master
[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta
[delta]
  navigate = true
  light = true
[merge]
  conflictstyle = diff3
[diff]
  colorMoved = default
[pull]
	rebase = true
[coderabbit]
	machineId = cli/781586070dd7421780f89fce6ea10686
