{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "garth-garmin-connect": {
      "type": "local",
      "command": ["uvx", "garth-mcp-server"],
      "environment": {
        "GARTH_TOKEN": "{env:GARTH_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "formatter": {
    "php-cs-fixer": {
      "command": ["ddev", "exec", "vendor/bin/php-cs-fixer", "fix", "$FILE"],
      "extensions": [".php"]
    }
  },
  "mode": {
    "build": {
      "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    },
    "plan": {
      "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    }
  }
}
