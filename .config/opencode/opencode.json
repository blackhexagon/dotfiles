{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "~/Work/**": "allow"
    }
  },
  "plugin": ["opencode-claude-auth"],
  "mcp": {
    "next-devtools": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "next-devtools-mcp@latest"]
    },
    "garth-garmin-connect": {
      "type": "local",
      "command": ["uvx", "garth-mcp-server"],
      "enabled": false,
      "environment": {
        "GARTH_TOKEN": "{env:GARTH_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "nette-inspector": {
      "type": "local",
      "command": ["ddev", "php", "vendor/bin/mcp-inspector"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "formatter": {
    "php-cs-fixer": {
      "command": ["ddev", "exec", "vendor/bin/php-cs-fixer", "fix", "$FILE"],
      "extensions": [".php"]
    }
  },
  "mode": {
    "build": {
      "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    },
    "plan": {
      "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    }
  }
}
