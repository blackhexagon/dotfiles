{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "~/Work/**": "allow"
    }
  },
  "plugin": ["opencode-claude-auth", "opencode-wakatime"],
  "provider": {
    "anthropic": {}
  },
  "mcp": {
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "{env:FIGMA_CLIENT_ID}",
        "clientSecret": "{env:FIGMA_CLIENT_SECRET}"
      }
    },
    "next-devtools": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "next-devtools-mcp@latest"]
    },
    "garth-garmin-connect": {
      "type": "local",
      "command": ["uvx", "garth-mcp-server"],
      "enabled": false,
      "environment": {
        "GARTH_TOKEN": "{env:GARTH_TOKEN}"
      }
    }
  },
  "formatter": {
    "php-cs-fixer": {
      "command": ["ddev", "exec", "vendor/bin/php-cs-fixer", "fix", "$FILE"],
      "extensions": [".php"]
    }
  }
}
