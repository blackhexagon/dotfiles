{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "~/Work/**": "allow"
    }
  },
  "plugin": ["opencode-claude-auth"],
  "provider": {
    "anthropic": {}
  },
  "mcp": {
    "next-devtools": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "next-devtools-mcp@latest"]
    },
    "garth-garmin-connect": {
      "type": "local",
      "command": ["uvx", "garth-mcp-server"],
      "enabled": false,
      "environment": {
        "GARTH_TOKEN": "{env:GARTH_TOKEN}"
      }
    }
  },
  "formatter": {
    "php-cs-fixer": {
      "command": ["ddev", "exec", "vendor/bin/php-cs-fixer", "fix", "$FILE"],
      "extensions": [".php"]
    }
  }
}
