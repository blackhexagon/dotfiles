{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "~/Work/**": "allow"
    }
  },
  "plugin": ["opencode-claude-auth", "opencode-wakatime"],
  "provider": {
    "anthropic": {}
  },
  "mcp": {
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "{env:FIGMA_CLIENT_ID}",
        "clientSecret": "{env:FIGMA_CLIENT_SECRET}"
      },
      "enabled": false
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": false
    },
    "chome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/chromium"
      ],
      "enabled": false
    }
  },
  "formatter": {
    "php-cs-fixer": {
      "command": ["ddev", "exec", "vendor/bin/php-cs-fixer", "fix", "$FILE"],
      "extensions": [".php"]
    }
  }
}
